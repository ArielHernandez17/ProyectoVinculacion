# Puerto donde correrá el servidor Express
PORT=3000
# Host de la base de datos (nombre del servicio en docker-compose)
DB_HOST=db
# Puerto interno de MariaDB en el contenedor
DB_PORT=3306
# Usuario root de MariaDB
DB_USER=root
# Contraseña del root (coincide con MYSQL_ROOT_PASSWORD en docker-compose)
DB_PASSWORD=root123
# Nombre de la base de datos
DB_NAME=incidencias_db